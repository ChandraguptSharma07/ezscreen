   "source": [
    "# =============================================================================\n",
    "# AUTO-GENERATED BY ezscreen << ezscreen_version >> -- DO NOT EDIT\n",
    "# Run ID  : << run_id >>\n",
    "# Top N   : << top_n >>\n",
    "# GNINA CNN rescoring of existing UniDock poses (no re-docking)\n",
    "# =============================================================================\n",
    "RUN_ID  = '<< run_id >>'\n",
    "TOP_N   = << top_n >>\n",
    "print(f'GNINA rescore — {RUN_ID}  top {TOP_N} poses')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-02",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, stat, subprocess, sys, urllib.request\n",
    "\n",
    "def _run(cmd, timeout=600):\n",
    "    r = subprocess.run(cmd, shell=True, capture_output=True, timeout=timeout)\n",
    "    out = r.stdout.decode('utf-8', errors='replace')\n",
    "    err = r.stderr.decode('utf-8', errors='replace')\n",
    "    return r.returncode, out, err\n",
    "\n",
    "# rdkit is pre-installed on GPU kernels; install only if missing.\n",
    "try:\n",
    "    from rdkit import Chem\n",
    "    print('rdkit: already available')\n",
    "except ImportError:\n",
    "    print('rdkit: installing...')\n",
    "    _run(f'{sys.executable} -m pip install rdkit -q')\n",
    "\n",
    "# GNINA has no reliable pip/conda path on the Kaggle image, so we pull the\n",
    "# prebuilt static binary from the project's latest GitHub release. The\n",
    "# /releases/latest/download/ redirect always resolves to the newest asset.\n",
    "GNINA_BIN = '/kaggle/working/gnina'\n",
    "GNINA_OK  = False\n",
    "GNINA_ERR = ''\n",
    "try:\n",
    "    print('gnina: downloading static binary...')\n",
    "    urllib.request.urlretrieve(\n",
    "        'https://github.com/gnina/gnina/releases/latest/download/gnina', GNINA_BIN)\n",
    "    os.chmod(GNINA_BIN, os.stat(GNINA_BIN).st_mode | stat.S_IEXEC)\n",
    "    rc, out, err = _run(f'{GNINA_BIN} --version')\n",
    "    if rc == 0:\n",
    "        GNINA_OK = True\n",
    "        print('gnina:', out.strip().splitlines()[0] if out.strip() else 'ok')\n",
    "    else:\n",
    "        GNINA_ERR = f'gnina --version exited {rc}: {err[-400:]}'\n",
    "        print('gnina: FAILED —', GNINA_ERR)\n",
    "except Exception as e:\n",
    "    GNINA_ERR = f'gnina install failed: {e}'\n",
    "    print('gnina:', GNINA_ERR)\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-03",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import csv, json, pathlib\n",
    "\n",
    "# Kaggle mount path varies (/kaggle/input/<slug>/ or /kaggle/input/datasets/<user>/<slug>/),\n",
    "# so search from the root for the files regardless of mount structure.\n",
    "_base = pathlib.Path('/kaggle/input')\n",
    "_hits = list(_base.rglob('receptor_prep.pdb'))\n",
    "if not _hits:\n",
    "    raise FileNotFoundError(f'receptor_prep.pdb not found under {_base}. Tree: {list(_base.rglob(\"*\"))[:30]}')\n",
    "dataset = _hits[0].parent\n",
    "print(f'dataset dir: {dataset}')\n",
    "\n",
    "receptor_pdb = dataset / 'receptor_prep.pdb'\n",
    "poses_sdf    = dataset / 'gnina_poses.sdf'\n",
    "scores_csv   = dataset / 'scores_top_n.csv'\n",
    "\n",
    "for p in (receptor_pdb, poses_sdf, scores_csv):\n",
    "    if not p.exists():\n",
    "        raise FileNotFoundError(f'Missing dataset file: {p}')\n",
    "\n",
    "with scores_csv.open() as f:\n",
    "    score_rows = list(csv.DictReader(f))\n",
    "print(f'receptor: {receptor_pdb}  poses: {poses_sdf}  compounds: {len(score_rows)}')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-04",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from rdkit import Chem\n",
    "\n",
    "out_csv = pathlib.Path('/kaggle/working/cnn_scores.csv')\n",
    "scored_sdf = pathlib.Path('/kaggle/working/scored.sdf')\n",
    "rows = []\n",
    "\n",
    "if not GNINA_OK:\n",
    "    print('gnina unavailable — writing empty cnn_scores.csv (Vina-only fallback)')\n",
    "    pathlib.Path('/kaggle/working/gnina_error.txt').write_text(GNINA_ERR or 'gnina unavailable')\n",
    "else:\n",
    "    # --score_only evaluates each supplied pose without re-docking; CNN scoring is on\n",
    "    # by default (crossdock_default2018 ensemble; weights fetched on first call).\n",
    "    cmd = (\n",
    "        f'{GNINA_BIN} -r \"{receptor_pdb}\" -l \"{poses_sdf}\" '\n",
    "        f'--score_only -o \"{scored_sdf}\"'\n",
    "    )\n",
    "    print('running:', cmd)\n",
    "    rc, out, err = _run(cmd, timeout=3600)\n",
    "    if rc != 0:\n",
    "        print('gnina --score_only FAILED:', err[-1000:])\n",
    "        pathlib.Path('/kaggle/working/gnina_error.txt').write_text(err[-4000:])\n",
    "    else:\n",
    "        print(out[-1000:])\n",
    "        if scored_sdf.exists():\n",
    "            supplier = Chem.SDMolSupplier(str(scored_sdf), removeHs=False, sanitize=False)\n",
    "            for mol in supplier:\n",
    "                if mol is None:\n",
    "                    continue\n",
    "                lig_id = mol.GetProp('_Name') if mol.HasProp('_Name') else ''\n",
    "                if not lig_id:\n",
    "                    continue\n",
    "                def _prop(name):\n",
    "                    return mol.GetProp(name) if mol.HasProp(name) else ''\n",
    "                rows.append({\n",
    "                    'lig_id':      lig_id,\n",
    "                    'CNNscore':    _prop('CNNscore'),\n",
    "                    'CNNaffinity': _prop('CNNaffinity'),\n",
    "                })\n",
    "        print(f'parsed {len(rows)} rescored poses')\n",
    "\n",
    "with out_csv.open('w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['lig_id', 'CNNscore', 'CNNaffinity'])\n",
    "    w.writeheader()\n",
    "    w.writerows(rows)\n",
    "print(f'wrote {out_csv}  ({len(rows)} rows)')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-05",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import zipfile\n",
    "zip_path = pathlib.Path('/kaggle/working/gnina_output.zip')\n",
    "with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:\n",
    "    zf.write(out_csv, 'cnn_scores.csv')\n",
    "pathlib.Path('/kaggle/working/done.flag').write_text('done')\n",
    "print('done')\n"
   ]
  }

