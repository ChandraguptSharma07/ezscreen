   "source": [
    "import subprocess, sys\n",
    "def _run(cmd, timeout=120):\n",
    "    r = subprocess.run(cmd, shell=True, capture_output=True, timeout=timeout)\n",
    "    if r.returncode != 0:\n",
    "        print('FAILED:', r.stderr.decode('utf-8', errors='replace')[-400:])\n",
    "    else:\n",
    "        print('ok')\n",
    "\n",
    "# rdkit: pre-installed on GPU kernels, not on CPU — install only if missing\n",
    "try:\n",
    "    from rdkit import Chem\n",
    "    print('rdkit: already available')\n",
    "except ImportError:\n",
    "    print('rdkit: installing...')\n",
    "    _run(f'{sys.executable} -m pip install rdkit -q')\n",
    "\n",
    "import os, shutil, sysconfig, urllib.request, zipfile\n",
    "\n",
    "print('openbabel-wheel: installing...')\n",
    "_run(f'{sys.executable} -m pip install openbabel-wheel -q')\n",
    "\n",
    "print('lxml: installing...')\n",
    "_run(f'{sys.executable} -m pip install lxml -q')\n",
    "\n",
    "# plip's pyproject.toml build system fails on the system Python here.\n",
    "# plip is pure Python so we bypass pip entirely: download zip, copy into site-packages.\n",
    "print('plip: installing from source zip...')\n",
    "_zip = '/tmp/plip_src.zip'\n",
    "urllib.request.urlretrieve(\n",
    "    'https://github.com/pharmai/plip/archive/refs/heads/master.zip', _zip)\n",
    "with zipfile.ZipFile(_zip) as _z:\n",
    "    _z.extractall('/tmp/plip_extracted')\n",
    "_site = sysconfig.get_path('purelib')\n",
    "shutil.copytree('/tmp/plip_extracted/plip-master/plip',\n",
    "                os.path.join(_site, 'plip'), dirs_exist_ok=True)\n",
    "print('plip: ok')\n",
    "\n",
    "print('dependencies ready')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-03",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import base64, csv, io, json, pathlib, shutil\n",
    "from rdkit import Chem\n",
    "\n",
    "# Kaggle mount path varies (/kaggle/input/<slug>/ or /kaggle/input/datasets/<user>/<slug>/)\n",
    "# Search from the root to find the files regardless of mount structure.\n",
    "_base = pathlib.Path('/kaggle/input')\n",
    "_hits = list(_base.rglob('receptor_prep.pdb'))\n",
    "if not _hits:\n",
    "    raise FileNotFoundError(f'receptor_prep.pdb not found anywhere under {_base}. Tree: {list(_base.rglob(\"*\"))[:30]}')\n",
    "dataset = _hits[0].parent\n",
    "print(f'dataset dir: {dataset}')\n",
    "\n",
    "receptor_pdb = dataset / 'receptor_prep.pdb'\n",
    "poses_sdf    = dataset / 'plip_poses.sdf'\n",
    "scores_csv   = dataset / 'scores_top_n.csv'\n",
    "\n",
    "for p in (receptor_pdb, poses_sdf, scores_csv):\n",
    "    if not p.exists():\n",
    "        raise FileNotFoundError(f'Missing dataset file: {p}')\n",
    "\n",
    "with scores_csv.open() as f:\n",
    "    score_rows = list(csv.DictReader(f))\n",
    "\n",
    "receptor_text = receptor_pdb.read_text()\n",
    "print(f'receptor: {receptor_pdb}  poses: {poses_sdf}  compounds: {len(score_rows)}')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-04",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "workdir = pathlib.Path('/kaggle/working/plip_tmp')\n",
    "workdir.mkdir(exist_ok=True)\n",
    "\n",
    "supplier = Chem.SDMolSupplier(str(poses_sdf), removeHs=False)\n",
    "mol_map = {}\n",
    "for mol in supplier:\n",
    "    if mol is None:\n",
    "        continue\n",
    "    lig_id = mol.GetProp('_Name') if mol.HasProp('_Name') else None\n",
    "    if lig_id:\n",
    "        mol_map[lig_id] = mol\n",
    "print(f'loaded {len(mol_map)} poses')\n",
    "\n",
    "def _sdf_b64(mol):\n",
    "    buf = io.StringIO()\n",
    "    w = Chem.SDWriter(buf)\n",
    "    w.write(mol)\n",
    "    w.close()\n",
    "    return base64.b64encode(buf.getvalue().encode()).decode()\n",
    "\n",
    "def _coords(obj, attr):\n",
    "    try:\n",
    "        c = getattr(obj, attr)\n",
    "        return [float(c[0]), float(c[1]), float(c[2])]\n",
    "    except Exception:\n",
    "        return [0.0, 0.0, 0.0]\n",
    "\n",
    "def _extract_interactions(bs):\n",
    "    interactions = []\n",
    "    try:\n",
    "        for hc in getattr(bs, 'hydrophobic_contacts', []):\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type': 'hydrophobic',\n",
    "                    'residue_number': int(getattr(hc, 'resnr', 0)),\n",
    "                    'residue_name':   str(getattr(hc, 'restype', '')),\n",
    "                    'chain':          str(getattr(hc, 'reschain', '')),\n",
    "                    'protein_atom':   str(getattr(hc, 'bsatom', '')),\n",
    "                    'ligand_atom':    str(getattr(hc, 'ligatom', '')),\n",
    "                    'protein_coords': _coords(hc, 'bsatom_coords') if hasattr(hc, 'bsatom_coords') else _coords(getattr(hc, 'bsatom', hc), 'coords'),\n",
    "                    'ligand_coords':  _coords(hc, 'ligatom_coords') if hasattr(hc, 'ligatom_coords') else _coords(getattr(hc, 'ligatom', hc), 'coords'),\n",
    "                    'distance': float(getattr(hc, 'distance', getattr(hc, 'dist', 0.0))),\n",
    "                    'angle': None,\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "\n",
    "        for hb in list(getattr(bs, 'hbonds_pdon', [])) + list(getattr(bs, 'hbonds_ldon', [])):\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type': 'hbond',\n",
    "                    'residue_number': int(getattr(hb, 'resnr', 0)),\n",
    "                    'residue_name':   str(getattr(hb, 'restype', '')),\n",
    "                    'chain':          str(getattr(hb, 'reschain', '')),\n",
    "                    'protein_atom':   str(getattr(hb, 'donoratom', '') or getattr(hb, 'acceptoratom', '')),\n",
    "                    'ligand_atom':    str(getattr(hb, 'acceptoratom', '') or getattr(hb, 'donoratom', '')),\n",
    "                    'protein_coords': _coords(hb, 'donorcoords') if hasattr(hb, 'donorcoords') else [0,0,0],\n",
    "                    'ligand_coords':  _coords(hb, 'acceptorcoords') if hasattr(hb, 'acceptorcoords') else [0,0,0],\n",
    "                    'distance': float(getattr(hb, 'distance_ah', 0) or getattr(hb, 'dist', 0)),\n",
    "                    'angle': float(getattr(hb, 'angle', 0)),\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "\n",
    "        for ps in getattr(bs, 'pistacking', []):\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type': 'pi_stack',\n",
    "                    'residue_number': int(getattr(ps, 'resnr', 0)),\n",
    "                    'residue_name':   str(getattr(ps, 'restype', '')),\n",
    "                    'chain':          str(getattr(ps, 'reschain', '')),\n",
    "                    'protein_atom':   str(getattr(ps, 'protcenter', '')),\n",
    "                    'ligand_atom':    str(getattr(ps, 'ligcenter', '')),\n",
    "                    'protein_coords': _coords(ps, 'protcenter'),\n",
    "                    'ligand_coords':  _coords(ps, 'ligcenter'),\n",
    "                    'distance': float(getattr(ps, 'distance', 0)),\n",
    "                    'angle': float(getattr(ps, 'angle', 0)),\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "\n",
    "        for pc in list(getattr(bs, 'pication_paro', [])) + list(getattr(bs, 'pication_laro', [])):\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type': 'pi_cation',\n",
    "                    'residue_number': int(getattr(pc, 'resnr', 0)),\n",
    "                    'residue_name':   str(getattr(pc, 'restype', '')),\n",
    "                    'chain':          str(getattr(pc, 'reschain', '')),\n",
    "                    'protein_atom':   str(getattr(pc, 'protcenter', '')),\n",
    "                    'ligand_atom':    str(getattr(pc, 'ligcenter', '')),\n",
    "                    'protein_coords': _coords(pc, 'protcenter'),\n",
    "                    'ligand_coords':  _coords(pc, 'ligcenter'),\n",
    "                    'distance': float(getattr(pc, 'distance', 0)),\n",
    "                    'angle': None,\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "\n",
    "        for sb in list(getattr(bs, 'saltbridge_lneg', [])) + list(getattr(bs, 'saltbridge_pneg', [])):\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type': 'salt_bridge',\n",
    "                    'residue_number': int(getattr(sb, 'resnr', 0)),\n",
    "                    'residue_name':   str(getattr(sb, 'restype', '')),\n",
    "                    'chain':          str(getattr(sb, 'reschain', '')),\n",
    "                    'protein_atom':   str(getattr(sb, 'protcenter', '')),\n",
    "                    'ligand_atom':    str(getattr(sb, 'ligcenter', '')),\n",
    "                    'protein_coords': _coords(sb, 'negative_center') if hasattr(sb, 'negative_center') else [0,0,0],\n",
    "                    'ligand_coords':  _coords(sb, 'positive_center') if hasattr(sb, 'positive_center') else [0,0,0],\n",
    "                    'distance': float(getattr(sb, 'distance', 0)),\n",
    "                    'angle': None,\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "\n",
    "        for hx in getattr(bs, 'halogen_bonds', []):\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type': 'halogen',\n",
    "                    'residue_number': int(getattr(hx, 'resnr', 0)),\n",
    "                    'residue_name':   str(getattr(hx, 'restype', '')),\n",
    "                    'chain':          str(getattr(hx, 'reschain', '')),\n",
    "                    'protein_atom':   str(getattr(hx, 'acc_orig_idx', '')),\n",
    "                    'ligand_atom':    str(getattr(hx, 'don_orig_idx', '')),\n",
    "                    'protein_coords': _coords(hx, 'acccoords') if hasattr(hx, 'acccoords') else [0,0,0],\n",
    "                    'ligand_coords':  _coords(hx, 'donorcoords') if hasattr(hx, 'donorcoords') else [0,0,0],\n",
    "                    'distance': float(getattr(hx, 'distance', 0)),\n",
    "                    'angle': float(getattr(hx, 'don_angle', 0)),\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "    except Exception as e:\n",
    "        print(f'    interaction extraction error: {e}')\n",
    "    return interactions\n",
    "\n",
    "print('helpers ready')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-05",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from plip.structure.preparation import PDBComplex\n",
    "\n",
    "results = []\n",
    "for rank, row in enumerate(score_rows, 1):\n",
    "    lig_id = row['ligand']\n",
    "    mol    = mol_map.get(lig_id)\n",
    "    entry  = {\n",
    "        'rank': rank, 'lig_id': lig_id,\n",
    "        'name': row.get('name', lig_id), 'score': row.get('score', ''),\n",
    "        'sdf_b64': None, 'plip_failed': False, 'plip_error': None,\n",
    "        'interactions': [],\n",
    "    }\n",
    "\n",
    "    if mol is None:\n",
    "        entry['plip_failed'] = True\n",
    "        entry['plip_error']  = 'pose not found in poses.sdf'\n",
    "        results.append(entry)\n",
    "        print(f'  [{rank}] {lig_id}: pose missing')\n",
    "        continue\n",
    "\n",
    "    entry['sdf_b64'] = _sdf_b64(mol)\n",
    "\n",
    "    try:\n",
    "        # Write ligand SDF, convert to PDB via OpenBabel for proper atom typing\n",
    "        lig_sdf = workdir / f'{lig_id}.sdf'\n",
    "        _w = Chem.SDWriter(str(lig_sdf))\n",
    "        _w.write(mol)\n",
    "        _w.close()\n",
    "\n",
    "        from openbabel import openbabel as ob\n",
    "        conv = ob.OBConversion()\n",
    "        conv.SetInAndOutFormats('sdf', 'pdb')\n",
    "        obmol = ob.OBMol()\n",
    "        conv.ReadFile(obmol, str(lig_sdf))\n",
    "        lig_pdb_text = conv.WriteString(obmol)\n",
    "\n",
    "        # Rename residue to LIG on all ATOM/HETATM lines so PLIP identifies it\n",
    "        lig_lines = []\n",
    "        for line in lig_pdb_text.splitlines():\n",
    "            if line.startswith(('ATOM  ', 'HETATM')):\n",
    "                line = 'HETATM' + line[6:17] + 'LIG' + line[20:]\n",
    "            if not line.startswith(('END', 'CONECT', 'MASTER')):\n",
    "                lig_lines.append(line)\n",
    "        lig_text = '\\n'.join(lig_lines) + '\\n'\n",
    "\n",
    "        # Strip terminal records from receptor so ligand lines aren't ignored\n",
    "        receptor_body = '\\n'.join(\n",
    "            l for l in receptor_text.splitlines()\n",
    "            if not l.startswith(('END', 'CONECT', 'MASTER'))\n",
    "        ).rstrip() + '\\nTER\\n'\n",
    "\n",
    "        complex_pdb = workdir / f'{lig_id}_complex.pdb'\n",
    "        complex_pdb.write_text(receptor_body + lig_text + 'END\\n')\n",
    "\n",
    "        mol_complex = PDBComplex()\n",
    "        mol_complex.load_pdb(str(complex_pdb))\n",
    "        mol_complex.analyze()\n",
    "\n",
    "        bs_keys = list(mol_complex.interaction_sets.keys())\n",
    "        if rank == 1:\n",
    "            print(f'  [debug] interaction_sets keys: {bs_keys}')\n",
    "        for bs in mol_complex.interaction_sets.values():\n",
    "            entry['interactions'].extend(_extract_interactions(bs))\n",
    "\n",
    "        print(f'  [{rank}] {lig_id}: {len(entry[\"interactions\"])} interactions')\n",
    "\n",
    "    except Exception as e:\n",
    "        entry['plip_failed'] = True\n",
    "        entry['plip_error']  = str(e)\n",
    "        print(f'  [{rank}] {lig_id}: PLIP failed — {e}')\n",
    "\n",
    "    results.append(entry)\n",
    "\n",
    "out_json = pathlib.Path('/kaggle/working/interactions.json')\n",
    "out_json.write_text(json.dumps(results, indent=2))\n",
    "print(f'wrote {out_json}  ({len(results)} entries)')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-06",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import zipfile\n",
    "shutil.rmtree(workdir, ignore_errors=True)\n",
    "zip_path = pathlib.Path('/kaggle/working/plip_output.zip')\n",
    "with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:\n",
    "    zf.write(out_json, 'interactions.json')\n",
    "pathlib.Path('/kaggle/working/done.flag').write_text('done')\n",
    "print('done')\n"
   ]
  }

 ]
