   "source": [
    "import subprocess, sys\n",
    "def _run(cmd):\n",
    "    r = subprocess.run(cmd, shell=True, capture_output=True)\n",
    "    if r.returncode != 0:\n",
    "        print(r.stderr.decode('utf-8', errors='replace')[:500])\n",
    "\n",
    "_run('apt-get install -y openbabel libopenbabel-dev -q')\n",
    "_run(f'{sys.executable} -m pip install plip rdkit-pypi -q')\n",
    "print('dependencies ready')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-03",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import csv, pathlib, shutil\n",
    "\n",
    "dataset = pathlib.Path(DATASET)\n",
    "receptor_pdb = dataset / 'receptor_prep.pdb'\n",
    "poses_sdf    = dataset / 'plip_poses.sdf'\n",
    "scores_csv   = dataset / 'scores_top_n.csv'\n",
    "\n",
    "for p in (receptor_pdb, poses_sdf, scores_csv):\n",
    "    if not p.exists():\n",
    "        raise FileNotFoundError(f'Missing dataset file: {p}')\n",
    "\n",
    "with scores_csv.open() as f:\n",
    "    score_rows = list(csv.DictReader(f))\n",
    "\n",
    "score_map = {r['ligand']: r for r in score_rows}\n",
    "print(f'receptor: {receptor_pdb}  poses: {poses_sdf}  compounds: {len(score_rows)}')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-04",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import base64, io, os, tempfile, xml.etree.ElementTree as ET\n",
    "from rdkit import Chem\n",
    "\n",
    "workdir = pathlib.Path('/kaggle/working/plip_tmp')\n",
    "workdir.mkdir(exist_ok=True)\n",
    "\n",
    "receptor_text = receptor_pdb.read_text()\n",
    "\n",
    "def _parse_plip_xml(xml_path):\n",
    "    interactions = []\n",
    "    tree = ET.parse(xml_path)\n",
    "    root = tree.getroot()\n",
    "    bs = root.find('.//bindingsite')\n",
    "    if bs is None:\n",
    "        return interactions\n",
    "\n",
    "    def _coords(el, x_tag, y_tag, z_tag):\n",
    "        try:\n",
    "            return [float(el.findtext(x_tag, 0)),\n",
    "                    float(el.findtext(y_tag, 0)),\n",
    "                    float(el.findtext(z_tag, 0))]\n",
    "        except (TypeError, ValueError):\n",
    "            return [0, 0, 0]\n",
    "\n",
    "    type_map = [\n",
    "        ('hydrophobic_interactions', 'hydrophobic',\n",
    "         'resnr', 'restype', 'reschain', 'atomtype', 'ligatom',\n",
    "         'protcarbonx', 'protcarbony', 'protcarbonz',\n",
    "         'ligcarbonx',  'ligcarbony',  'ligcarbonz',\n",
    "         'dist', None),\n",
    "        ('hydrogen_bonds', 'hbond',\n",
    "         'resnr', 'restype', 'reschain', 'donoratom', 'acceptoratom',\n",
    "         'donorx', 'donory', 'donorz',\n",
    "         'acceptorx', 'acceptory', 'acceptorz',\n",
    "         'dist_h-a', 'don_angle'),\n",
    "        ('pi_stacks', 'pi_stack',\n",
    "         'resnr', 'restype', 'reschain', 'protcenteratom', 'ligcenteratom',\n",
    "         'protcenterx', 'protcentery', 'protcenterz',\n",
    "         'ligcenterx',  'ligcentery',  'ligcenterz',\n",
    "         'centdist', 'angle'),\n",
    "        ('pi_cation_interactions', 'pi_cation',\n",
    "         'resnr', 'restype', 'reschain', 'protcenteratom', 'ligatom',\n",
    "         'protcenterx', 'protcentery', 'protcenterz',\n",
    "         'ligcenterx',  'ligcentery',  'ligcenterz',\n",
    "         'dist', None),\n",
    "        ('salt_bridges', 'salt_bridge',\n",
    "         'resnr', 'restype', 'reschain', 'protcenteratom', 'ligatom',\n",
    "         'protcenterx', 'protcentery', 'protcenterz',\n",
    "         'ligcenterx',  'ligcentery',  'ligcenterz',\n",
    "         'dist', None),\n",
    "        ('halogen_bonds', 'halogen',\n",
    "         'resnr', 'restype', 'reschain', 'donoratom', 'acceptoratom',\n",
    "         'donorx', 'donory', 'donorz',\n",
    "         'acceptorx', 'acceptory', 'acceptorz',\n",
    "         'dist', 'don_angle'),\n",
    "    ]\n",
    "\n",
    "    for (section, itype,\n",
    "         resnr_t, restype_t, reschain_t, protatom_t, ligatom_t,\n",
    "         px_t, py_t, pz_t, lx_t, ly_t, lz_t, dist_t, angle_t) in type_map:\n",
    "        container = bs.find(f'.//{section}')\n",
    "        if container is None:\n",
    "            continue\n",
    "        for el in container:\n",
    "            try:\n",
    "                interactions.append({\n",
    "                    'type':             itype,\n",
    "                    'residue_number':   int(el.findtext(resnr_t, 0)),\n",
    "                    'residue_name':     el.findtext(restype_t, ''),\n",
    "                    'chain':            el.findtext(reschain_t, ''),\n",
    "                    'protein_atom':     el.findtext(protatom_t, ''),\n",
    "                    'ligand_atom':      el.findtext(ligatom_t, ''),\n",
    "                    'protein_coords':   _coords(el, px_t, py_t, pz_t),\n",
    "                    'ligand_coords':    _coords(el, lx_t, ly_t, lz_t),\n",
    "                    'distance':         float(el.findtext(dist_t, 0) or 0),\n",
    "                    'angle':            float(el.findtext(angle_t, 0) or 0) if angle_t else None,\n",
    "                })\n",
    "            except Exception:\n",
    "                pass\n",
    "    return interactions\n",
    "\n",
    "print('PLIP parsing helpers ready')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-05",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "\n",
    "supplier = Chem.SDMolSupplier(str(poses_sdf), removeHs=False)\n",
    "mol_map = {}\n",
    "for mol in supplier:\n",
    "    if mol is None:\n",
    "        continue\n",
    "    lig_id = mol.GetProp('_Name') if mol.HasProp('_Name') else None\n",
    "    if lig_id:\n",
    "        mol_map[lig_id] = mol\n",
    "\n",
    "results = []\n",
    "for rank, row in enumerate(score_rows, 1):\n",
    "    lig_id = row['ligand']\n",
    "    mol = mol_map.get(lig_id)\n",
    "    entry = {\n",
    "        'rank':       rank,\n",
    "        'lig_id':     lig_id,\n",
    "        'name':       row.get('name', lig_id),\n",
    "        'score':      row.get('score', ''),\n",
    "        'sdf_b64':    None,\n",
    "        'plip_failed': False,\n",
    "        'plip_error':  None,\n",
    "        'interactions': [],\n",
    "    }\n",
    "\n",
    "    if mol is None:\n",
    "        entry['plip_failed'] = True\n",
    "        entry['plip_error']  = 'pose not found in poses.sdf'\n",
    "        results.append(entry)\n",
    "        print(f'  [{rank}] {lig_id}: pose missing')\n",
    "        continue\n",
    "\n",
    "    # encode SDF for the viewer\n",
    "    writer = Chem.SDWriter(io.StringIO())\n",
    "    sdf_buf = io.StringIO()\n",
    "    w = Chem.SDWriter(sdf_buf)\n",
    "    w.write(mol)\n",
    "    w.close()\n",
    "    entry['sdf_b64'] = base64.b64encode(sdf_buf.getvalue().encode()).decode()\n",
    "\n",
    "    try:\n",
    "        from plip.structure.preparation import PDBComplex\n",
    "\n",
    "        # write merged complex PDB\n",
    "        lig_pdb_lines = []\n",
    "        for atom in mol.GetAtoms():\n",
    "            pos = mol.GetConformer().GetAtomPosition(atom.GetIdx())\n",
    "            sym = atom.GetSymbol().upper()\n",
    "            line = (f'HETATM{atom.GetIdx()+1:5d}  {sym:<3s} LIG A   1    '\n",
    "                    f'{pos.x:8.3f}{pos.y:8.3f}{pos.z:8.3f}  1.00  0.00          {sym:>2s}')\n",
    "            lig_pdb_lines.append(line)\n",
    "\n",
    "        complex_pdb = workdir / f'{lig_id}_complex.pdb'\n",
    "        complex_pdb.write_text(receptor_text + '\\n'.join(lig_pdb_lines) + '\\nEND\\n')\n",
    "\n",
    "        mol_complex = PDBComplex()\n",
    "        mol_complex.load_pdb(str(complex_pdb))\n",
    "        mol_complex.analyze()\n",
    "\n",
    "        # find the ligand binding site\n",
    "        bs_key = next(iter(mol_complex.interaction_sets), None)\n",
    "        if bs_key:\n",
    "            from plip.exchange.report import StructureReport\n",
    "            report = StructureReport(mol_complex)\n",
    "            xml_path = workdir / f'{lig_id}.xml'\n",
    "            xml_path.write_text(report.generate_xml().decode('utf-8', errors='replace'))\n",
    "            entry['interactions'] = _parse_plip_xml(xml_path)\n",
    "\n",
    "        print(f'  [{rank}] {lig_id}: {len(entry[\"interactions\"])} interactions')\n",
    "\n",
    "    except Exception as e:\n",
    "        entry['plip_failed'] = True\n",
    "        entry['plip_error']  = str(e)\n",
    "        print(f'  [{rank}] {lig_id}: PLIP failed — {e}')\n",
    "\n",
    "    results.append(entry)\n",
    "\n",
    "out_json = pathlib.Path('/kaggle/working/interactions.json')\n",
    "out_json.write_text(json.dumps(results, indent=2))\n",
    "print(f'\\nwrote {out_json}  ({len(results)} entries)')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-06",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import zipfile\n",
    "\n",
    "shutil.rmtree(workdir, ignore_errors=True)\n",
    "\n",
    "zip_path = pathlib.Path('/kaggle/working/plip_output.zip')\n",
    "with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:\n",
    "    zf.write(out_json, 'interactions.json')\n",
    "\n",
    "pathlib.Path('/kaggle/working/done.flag').write_text('done')\n",
    "print('done')\n"
   ]
  }

 ]
}
