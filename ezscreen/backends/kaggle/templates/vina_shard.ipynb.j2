    "        w.writerows({k: v for k, v in r.items() if k != '_path'} for r in rows)\n",
    "\n",
    "# Write a per-ligand failure log so we can diagnose why poses were rejected.\n",
    "if failed_rows:\n",
    "    from collections import Counter\n",
    "    reason_counts = Counter(r['reason'] for r in failed_rows)\n",
    "    with open('/kaggle/working/failed_docking.csv', 'w', newline='') as f:\n",
    "        w = csv.DictWriter(f, fieldnames=['ligand', 'raw_score', 'reason'])\n",
    "        w.writeheader()\n",
    "        w.writerows(failed_rows)\n",
    "    print(f'  failed_docking.csv: {len(failed_rows)} entries — {dict(reason_counts)}')\n",
    "\n",
    "if not rows:\n",
    "    import json\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
