   "source": [
    "<% if prep_on_kaggle %>\n",
    "import csv, pathlib\n",
    "from rdkit import Chem\n",
    "from rdkit.Chem import AllChem, AddHs\n",
    "from rdkit.Chem.Descriptors import MolWt\n",
    "from rdkit.Chem.rdMolDescriptors import CalcNumHeavyAtoms, CalcNumRotatableBonds\n",
    "from meeko import MoleculePreparation, PDBQTWriterLegacy\n",
    "\n",
    "PDBQT_DIR = pathlib.Path('/kaggle/working/ligands/')\n",
    "PDBQT_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "MAX_HEAVY_ATOMS = << max_heavy_atoms >>\n",
    "MAX_MW = << max_mw >>\n",
    "MAX_ROT_BONDS = << max_rotatable_bonds >>\n",
    "\n",
    "_AUTODOCK_ATOMIC_NUMS = frozenset({1,6,7,8,9,12,15,16,17,20,25,26,30,35,53})\n",
    "\n",
    "pdbqt_files = []\n",
    "index_rows = []\n",
    "filtered_rows = []\n",
    "_prep_passed = 0\n",
    "_prep_failed = 0\n",
    "_global_idx = 0\n",
    "\n",
    "for _shard_path in LIGAND_PATHS:\n",
    "    for _line in _shard_path.read_text().splitlines():\n",
    "        _line = _line.strip()\n",
    "        if not _line or _line.startswith('#'):\n",
    "            continue\n",
    "        _parts = _line.split('\\t', 1)\n",
    "        _smiles = _parts[0]\n",
    "        _mol_name = _parts[1].strip() if len(_parts) > 1 else ''\n",
    "        _global_idx += 1\n",
    "\n",
    "        _mol = Chem.MolFromSmiles(_smiles)\n",
    "        if _mol is None:\n",
    "            _prep_failed += 1\n",
    "            continue\n",
    "\n",
    "        if (CalcNumHeavyAtoms(_mol) > MAX_HEAVY_ATOMS or\n",
    "                MolWt(_mol) > MAX_MW or\n",
    "                CalcNumRotatableBonds(_mol) > MAX_ROT_BONDS):\n",
    "            filtered_rows.append({'name': _mol_name, 'smiles': _smiles})\n",
    "            continue\n",
    "\n",
    "        if any(a.GetAtomicNum() not in _AUTODOCK_ATOMIC_NUMS for a in _mol.GetAtoms()):\n",
    "            _prep_failed += 1\n",
    "            continue\n",
    "\n",
    "        try:\n",
    "            _mol_h = AddHs(_mol)\n",
    "            _params = AllChem.ETKDGv3()\n",
    "            _params.randomSeed = 42\n",
    "            if AllChem.EmbedMolecule(_mol_h, _params) == -1:\n",
    "                _prep_failed += 1\n",
    "                continue\n",
    "            AllChem.MMFFOptimizeMolecule(_mol_h, maxIters=200)\n",
    "        except Exception:\n",
    "            _prep_failed += 1\n",
    "            continue\n",
    "\n",
    "        try:\n",
    "            _setups = MoleculePreparation().prepare(_mol_h)\n",
    "            _pdbqt, _ok, _ = PDBQTWriterLegacy.write_string(_setups[0])\n",
    "            if not _ok:\n",
    "                _prep_failed += 1\n",
    "                continue\n",
    "        except Exception:\n",
    "            _prep_failed += 1\n",
    "            continue\n",
    "\n",
    "        _lig_id = f'nb<< notebook_index >>_lig_{_prep_passed:05d}'\n",
    "        _raw = f'REMARK lig_id {_lig_id}\\n' + _pdbqt\n",
    "        _clean = '\\n'.join(ln for ln in _raw.splitlines() if ln.strip() != 'END')\n",
    "        _p = PDBQT_DIR / f'{_lig_id}.pdbqt'\n",
    "        _p.write_text(_clean)\n",
    "        pdbqt_files.append(str(_p))\n",
    "        index_rows.append({'ligand': _lig_id, 'name': _mol_name, 'smiles': _smiles})\n",
    "        _prep_passed += 1\n",
    "\n",
    "with open('/kaggle/working/index.csv', 'w', newline='') as _f:\n",
    "    _w = csv.DictWriter(_f, fieldnames=['ligand', 'name', 'smiles'])\n",
    "    _w.writeheader()\n",
    "    _w.writerows(index_rows)\n",
    "\n",
    "if filtered_rows:\n",
    "    with open('/kaggle/working/filtered_gpu_size.csv', 'w', newline='') as _f:\n",
    "        _w = csv.DictWriter(_f, fieldnames=['name', 'smiles'])\n",
    "        _w.writeheader()\n",
    "        _w.writerows(filtered_rows)\n",
    "\n",
    "if len(pdbqt_files) == 1:\n",
    "    import shutil as _sh\n",
    "    _pad = PDBQT_DIR / 'lig_pad_00000.pdbqt'\n",
    "    _sh.copy2(pdbqt_files[0], _pad)\n",
    "    pdbqt_files.append(str(_pad))\n",
    "    print('Padded to 2 ligands (UniDock 1-ligand batch workaround)')\n",
    "\n",
    "if not pdbqt_files:\n",
    "    import json as _json\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "        _json.dumps({'cell': 'ligand_prep', 'message': f'No dockable ligands. input={_global_idx} filtered={len(filtered_rows)} failed={_prep_failed}'})\n",
    "    )\n",
    "    raise RuntimeError('No dockable ligands after prep')\n",
    "\n",
    "print(f'Cell 6 done: {_prep_passed} dockable, {len(filtered_rows)} GPU-filtered, {_prep_failed} failed (of {_global_idx} input)')\n",
    "<% else %>\n",
    "import pathlib, re\n",
    "\n",
    "# Ligands arrive as multi-molecule PDBQT shards (prepared locally).\n",
    "# Split every shard into individual files; use REMARK lig_id for filenames\n",
    "# so scores.csv IDs match the local index.csv.\n",
    "PDBQT_DIR = pathlib.Path('/kaggle/working/ligands/')\n",
    "PDBQT_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "pdbqt_files = []\n",
    "_global_idx = 0\n",
    "\n",
    "for _shard_path in LIGAND_PATHS:\n",
    "    text = _shard_path.read_text()\n",
    "    # Split on TORSDOF boundaries (each molecule ends with TORSDOF N).\n",
    "    _marked = re.sub(r'(^TORSDOF[ \\t]+\\d+)', r'\\1\\nSPLIT_HERE', text, flags=re.MULTILINE)\n",
    "    for _b in _marked.split('SPLIT_HERE'):\n",
    "        # Strip END records -- UniDock 1.1.0 rejects END tags in ligand files\n",
    "        _clean = '\\n'.join(ln for ln in _b.splitlines() if ln.strip() != 'END').strip()\n",
    "        if not _clean:\n",
    "            continue\n",
    "        if not any(ln.startswith(('ATOM', 'HETATM')) for ln in _clean.splitlines()):\n",
    "            continue\n",
    "        # Prefer the injected REMARK lig_id for the filename so scores align with index.csv\n",
    "        _lig_id = None\n",
    "        for _ln in _clean.splitlines():\n",
    "            if _ln.startswith('REMARK lig_id '):\n",
    "                _lig_id = _ln.split()[-1]\n",
    "                break\n",
    "        _fname = f'{_lig_id}.pdbqt' if _lig_id else f'lig_{_global_idx:05d}.pdbqt'\n",
    "        p = PDBQT_DIR / _fname\n",
    "        p.write_text(_clean)\n",
    "        pdbqt_files.append(str(p))\n",
    "        _global_idx += 1\n",
    "\n",
    "if not pdbqt_files:\n",
    "    import json\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "        json.dumps({'cell': 'ligand_split', 'message': 'No valid PDBQT blocks found in shards'})\n",
    "    )\n",
    "    raise RuntimeError('Empty ligand shards')\n",
    "\n",
    "# UniDock 1.1.0 has a GPU batch grouping bug with < 2 ligands:\n",
    "# all group sizes become INT_MIN and no poses are produced.\n",
    "# Pad to at least 2 by duplicating the first ligand.\n",
    "if len(pdbqt_files) == 1:\n",
    "    import shutil\n",
    "    _pad = PDBQT_DIR / 'lig_pad_00000.pdbqt'\n",
    "    shutil.copy2(pdbqt_files[0], _pad)\n",
    "    pdbqt_files.append(str(_pad))\n",
    "    print('Padded batch to 2 ligands (UniDock 1-ligand batch workaround)')\n",
    "\n",
    "print(f'Cell 6 done: {_global_idx} ligand(s) from {len(LIGAND_PATHS)} shard(s) ready')\n",
    "<% endif %>"
   ]
  },

