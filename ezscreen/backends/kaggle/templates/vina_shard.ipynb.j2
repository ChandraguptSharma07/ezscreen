  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json, pathlib, subprocess\n",
    "\n",
    "def _write_error(cell, msg):\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "        json.dumps({'cell': cell, 'message': msg})\n",
    "    )\n",
    "\n",
    "try:\n",
    "    from pdbfixer import PDBFixer\n",
    "    from openmm.app import PDBFile\n",
    "\n",
    "    fixer = PDBFixer(filename=str(RECEPTOR_PATH))\n",
    "    fixer.findMissingResidues()\n",
    "    fixer.findNonstandardResidues()\n",
    "    fixer.replaceNonstandardResidues()\n",
    "    fixer.removeHeterogens(keepWater=False)\n",
    "    fixer.findMissingAtoms()\n",
    "    fixer.addMissingAtoms()\n",
    "    fixer.addMissingHydrogens(<< ph >>)\n",
    "\n",
    "    FIXED_PDB = pathlib.Path('/kaggle/working/receptor_fixed.pdb')\n",
    "    with FIXED_PDB.open('w') as f:\n",
    "        PDBFile.writeFile(fixer.topology, fixer.positions, f)\n",
    "\n",
    "except Exception as e:\n",
    "    _write_error('receptor_prep', str(e))\n",
    "    raise\n",
    "\n",
    "try:\n",
    "    import subprocess, shutil\n",
    "    exe = shutil.which('mk_prepare_receptor') or 'mk_prepare_receptor'\n",
    "    RECEPTOR_PDBQT = pathlib.Path('/kaggle/working/receptor.pdbqt')\n",
    "    r = subprocess.run([exe, '-i', str(FIXED_PDB), '-o', str(RECEPTOR_PDBQT)],\n",
    "                       capture_output=True, text=True)\n",
    "    if r.returncode != 0:\n",
    "        raise RuntimeError(r.stderr)\n",
    "except Exception as e:\n",
    "    _write_error('receptor_meeko', str(e))\n",
    "    raise\n",
    "\n",
    "print(f'Cell 5 done: receptor prepared → {RECEPTOR_PDBQT}')\n"
   ]
  },

  {
   "cell_type": "code",
