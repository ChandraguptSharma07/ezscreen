   "metadata": {},
   "outputs": [],
   "source": [
    "import json, pathlib, shutil, subprocess\n",
    "from rdkit.Chem import SDMolSupplier, SDWriter, AddHs, AllChem\n",
    "from meeko import MoleculePreparation, PDBQTWriterLegacy\n",
    "\n",
    "LIGAND_PDBQT = pathlib.Path('/kaggle/working/ligands.pdbqt')\n",
    "FAILED_SDF   = pathlib.Path('/kaggle/working/failed_prep.sdf')\n",
    "\n",
    "try:\n",
    "    from scrubber import Scrubber\n",
    "    _scrub = Scrubber(pH=<< ph >>)\n",
    "except ImportError:\n",
    "    _scrub = None\n",
    "\n",
    "prep = MoleculePreparation()\n",
    "failed_writer = SDWriter(str(FAILED_SDF))\n",
    "pdbqt_lines, n_ok, n_fail = [], 0, 0\n",
    "\n",
    "for mol in SDMolSupplier(str(LIGAND_PATH), removeHs=False, sanitize=True):\n",
    "    if mol is None:\n",
    "        n_fail += 1\n",
    "        continue\n",
    "    try:\n",
    "        if _scrub:\n",
    "            mol = _scrub(mol)\n",
    "        mol_h = AddHs(mol)\n",
    "        params = AllChem.ETKDGv3()\n",
    "        params.randomSeed = 42\n",
    "        if AllChem.EmbedMolecule(mol_h, params) == -1:\n",
    "            raise ValueError('conformer failed')\n",
    "        AllChem.MMFFOptimizeMolecule(mol_h, maxIters=200)\n",
    "        setups = prep.prepare(mol_h)\n",
    "        pdbqt, ok, _ = PDBQTWriterLegacy.write_string(setups[0])\n",
    "        if not ok:\n",
    "            raise ValueError('meeko write failed')\n",
    "        pdbqt_lines.append(pdbqt)\n",
    "        n_ok += 1\n",
    "    except Exception:\n",
    "        n_fail += 1\n",
    "        failed_writer.write(mol)\n",
    "\n",
    "failed_writer.close()\n",
    "LIGAND_PDBQT.write_text('\\n'.join(pdbqt_lines))\n",
    "print(f'Cell 6 done: {n_ok} ligands prepared, {n_fail} failed')\n"
   ]
  },

