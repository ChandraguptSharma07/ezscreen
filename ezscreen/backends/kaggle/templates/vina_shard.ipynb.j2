    "import pathlib\n",
    "\n",
    "RECEPTOR_PATH = pathlib.Path('<< receptor_dataset_path >>')\n",
    "LIGAND_PATH   = pathlib.Path('<< ligand_dataset_path >>')\n",
    "\n",
    "assert RECEPTOR_PATH.exists(), f'Receptor not found: {RECEPTOR_PATH}'\n",
    "assert LIGAND_PATH.exists(),   f'Ligand shard not found: {LIGAND_PATH}'\n",
    "\n",
    "print(f'Receptor : {RECEPTOR_PATH}')\n",
    "print(f'Ligand   : {LIGAND_PATH}  ({LIGAND_PATH.stat().st_size // 1024} KB)')\n",
    "print('Cell 4 done: inputs loaded')\n"
   ]
