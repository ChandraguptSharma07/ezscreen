   "source": [
    "import json, pathlib\n",
    "\n",
    "# Kaggle mounts datasets under /kaggle/input/<slug>/ but sometimes adds\n",
    "# a nested subdirectory with the same name. Discover files dynamically.\n",
    "_input_root = pathlib.Path('/kaggle/input')\n",
    "\n",
    "_receptor_candidates = list(_input_root.rglob('receptor.pdbqt'))\n",
    "assert _receptor_candidates, (\n",
    "    f'receptor.pdbqt not found anywhere under {_input_root}\\n'\n",
    "    f'Contents: {[str(p) for p in _input_root.rglob(\"*\")[:20]]}'\n",
    ")\n",
    "RECEPTOR_PATH = _receptor_candidates[0]\n",
    "\n",
    "# This notebook is responsible for the following shard files:\n",
    "SHARD_FILENAMES = [<% for fn in shard_filenames %>'<< fn >>'<% if not loop.last %>, <% endif %><% endfor %>]\n",
    "LIGAND_PATHS = []\n",
    "for _fn in SHARD_FILENAMES:\n",
    "    _candidates = list(_input_root.rglob(_fn))\n",
    "    assert _candidates, (\n",
    "        f'{_fn} not found anywhere under {_input_root}\\n'\n",
    "        f'Contents: {[str(p) for p in _input_root.rglob(\"*\")[:20]]}'\n",
    "    )\n",
    "    LIGAND_PATHS.append(_candidates[0])\n",
    "\n",
    "print(f'Receptor : {RECEPTOR_PATH}')\n",
    "for _lp in LIGAND_PATHS:\n",
    "    print(f'Shard    : {_lp}  ({_lp.stat().st_size // 1024} KB)')\n",
    "print(f'Cell 4 done: {len(LIGAND_PATHS)} shard(s) loaded')\n"
   ]
  },

