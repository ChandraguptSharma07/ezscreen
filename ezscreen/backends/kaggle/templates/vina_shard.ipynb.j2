   "source": [
    "import json, pathlib, subprocess, shutil\n",
    "\n",
    "def _write_error(cell, msg):\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "        json.dumps({'cell': cell, 'message': msg})\n",
    "    )\n",
    "\n",
    "# GPU\n",
    "r = subprocess.run('nvidia-smi --query-gpu=name,memory.total --format=csv,noheader',\n",
    "                   shell=True, capture_output=True, text=True)\n",
    "if r.returncode != 0:\n",
    "    _write_error('env_check', 'nvidia-smi failed -- no GPU available')\n",
    "    raise RuntimeError('No GPU available')\n",
    "print('GPU:', r.stdout.strip())\n",
    "\n",
    "# Disk\n",
    "usage = shutil.disk_usage('/kaggle/working')\n",
    "free_gb = usage.free / 1e9\n",
    "print(f'Free disk: {free_gb:.1f} GB')\n",
    "if free_gb < 2:\n",
    "    _write_error('env_check', f'Low disk: {free_gb:.1f} GB')\n",
    "    raise RuntimeError('Insufficient disk space')\n",
    "\n",
    "print('Cell 3 done: environment ok')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-04",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pathlib\n",
    "\n",
    "# Kaggle mounts datasets under /kaggle/input/<slug>/ but sometimes adds\n",
    "# a nested subdirectory with the same name. Discover files dynamically.\n",
    "_input_root = pathlib.Path('/kaggle/input')\n",
    "\n",
    "_receptor_candidates = list(_input_root.rglob('receptor.pdbqt'))\n",
    "assert _receptor_candidates, (\n",
    "    f'receptor.pdbqt not found anywhere under {_input_root}\\n'\n",
    "    f'Contents: {[str(p) for p in _input_root.rglob(\"*\")[:20]]}'\n",
    ")\n",
    "RECEPTOR_PATH = _receptor_candidates[0]\n",
    "\n",
    "_ligand_candidates = list(_input_root.rglob('<< shard_filename >>'))\n",
    "assert _ligand_candidates, (\n",
    "    f'<< shard_filename >> not found anywhere under {_input_root}\\n'\n",
    "    f'Contents: {[str(p) for p in _input_root.rglob(\"*\")[:20]]}'\n",
    ")\n",
    "LIGAND_PATH = _ligand_candidates[0]\n",
    "\n",
    "print(f'Receptor : {RECEPTOR_PATH}')\n",
    "print(f'Ligand   : {LIGAND_PATH}  ({LIGAND_PATH.stat().st_size // 1024} KB)')\n",
    "print('Cell 4 done: inputs loaded')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-05",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Receptor is already fully prepared locally (pdbfixer + meeko) and uploaded\n",
    "# as receptor.pdbqt -- use it directly, no need to re-run prep on Kaggle\n",
    "RECEPTOR_PDBQT = RECEPTOR_PATH\n",
    "assert RECEPTOR_PDBQT.exists(), f'Receptor PDBQT not found: {RECEPTOR_PDBQT}'\n",
    "print(f'Cell 5 done: receptor PDBQT ready -> {RECEPTOR_PDBQT}')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-06",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pathlib, re\n",
    "\n",
    "# Ligands are already prepared as a multi-molecule PDBQT (done locally).\n",
    "# Split into individual files so unidock can accept them via --gpu_batch.\n",
    "PDBQT_DIR = pathlib.Path('/kaggle/working/ligands/')\n",
    "PDBQT_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "text = LIGAND_PATH.read_text()\n",
    "# Split on TORSDOF boundaries (each molecule ends with TORSDOF N).\n",
    "# Splitting on every REMARK line incorrectly fragments multi-REMARK headers\n",
    "# (IDX, H PARENT, etc.) that belong to the same molecule.\n",
    "_marked = re.sub(r'(^TORSDOF[ \\t]+\\d+)', r'\\1\\nSPLIT_HERE', text, flags=re.MULTILINE)\n",
    "blocks = []\n",
    "for _b in _marked.split('SPLIT_HERE'):\n",
    "    # Strip END records -- UniDock 1.1.0 rejects END tags in ligand files\n",
    "    _clean = '\\n'.join(ln for ln in _b.splitlines() if ln.strip() != 'END').strip()\n",
    "    if _clean:\n",
    "        blocks.append(_clean)\n",
    "\n",
    "pdbqt_files = []\n",
    "for i, block in enumerate(blocks):\n",
    "    if not any(ln.startswith(('ATOM', 'HETATM')) for ln in block.splitlines()):\n",
    "        continue\n",
    "    p = PDBQT_DIR / f'lig_{i:05d}.pdbqt'\n",
    "    p.write_text(block)\n",
    "    pdbqt_files.append(str(p))\n",
    "\n",
    "if not pdbqt_files:\n",
    "    import json\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "        json.dumps({'cell': 'ligand_split', 'message': 'No valid PDBQT blocks found in shard'})\n",
    "    )\n",
    "    raise RuntimeError('Empty ligand shard')\n",
    "\n",
    "# UniDock 1.1.0 has a GPU batch grouping bug with < 2 ligands:\n",
    "# all group sizes become INT_MIN and no poses are produced.\n",
    "# Pad to at least 2 by duplicating the first ligand.\n",
    "if len(pdbqt_files) == 1:\n",
    "    import shutil\n",
    "    _pad = PDBQT_DIR / 'lig_pad_00000.pdbqt'\n",
    "    shutil.copy2(pdbqt_files[0], _pad)\n",
    "    pdbqt_files.append(str(_pad))\n",
    "    print('Padded batch to 2 ligands (UniDock 1-ligand batch workaround)')\n",
    "\n",
    "print(f'Cell 6 done: {len(pdbqt_files)} ligand PDBQT files ready')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-07",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json, os, pathlib, traceback\n",
    "\n",
    "ERROR_JSON = pathlib.Path('/kaggle/working/error.json')\n",
    "\n",
    "def _write_error(cell, msg):\n",
    "    ERROR_JSON.write_text(json.dumps({'cell': cell, 'message': msg}))\n",
    "\n",
    "BOX_CENTER   = [<< box_center[0] >>, << box_center[1] >>, << box_center[2] >>]\n",
    "BOX_SIZE     = [<< box_size[0] >>,   << box_size[1] >>,   << box_size[2] >>]\n",
    "EXHAUSTIVE   = << exhaustiveness >>\n",
    "NUM_MODES    = << num_modes >>\n",
    "REFINE_STEP  = << refine_step >>\n",
    "MAX_STEP     = << max_step >>\n",
    "if EXHAUSTIVE <= 8:\n",
    "    SEARCH_MODE = 'fast'\n",
    "elif EXHAUSTIVE <= 16:\n",
    "    SEARCH_MODE = 'balance'\n",
    "else:\n",
    "    SEARCH_MODE = 'detail'\n",
    "\n",
    "DOCKED_DIR = pathlib.Path('/kaggle/working/docked')\n",
    "DOCKED_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "import subprocess, shutil\n",
    "\n",
    "try:\n",
    "    _unidock_bin = shutil.which('unidock')\n",
    "    if _unidock_bin is None:\n",
    "        raise RuntimeError('unidock binary not found in PATH')\n",
    "    print(f'Using binary: {_unidock_bin}')\n",
    "\n",
    "    # Print CUDA/driver info\n",
    "    subprocess.run('nvidia-smi', shell=True)\n",
    "\n",
    "    cmd = [\n",
    "        _unidock_bin,\n",
    "        '--receptor', str(RECEPTOR_PDBQT),\n",
    "        '--gpu_batch', *pdbqt_files,\n",
    "        '--dir', str(DOCKED_DIR),\n",
    "        '--center_x', str(BOX_CENTER[0]),\n",
    "        '--center_y', str(BOX_CENTER[1]),\n",
    "        '--center_z', str(BOX_CENTER[2]),\n",
    "        '--size_x',   str(BOX_SIZE[0]),\n",
    "        '--size_y',   str(BOX_SIZE[1]),\n",
    "        '--size_z',   str(BOX_SIZE[2]),\n",
    "        '--exhaustiveness', str(EXHAUSTIVE),\n",
    "        '--num_modes',      str(NUM_MODES),\n",
    "        '--scoring',        'vina',\n",
    "    ]\n",
    "    print('Running:', ' '.join(cmd[:6]), '... [truncated]')\n",
    "    r = subprocess.run(cmd, capture_output=True, text=True)\n",
    "    print(f'exit code: {r.returncode}')\n",
    "    print('--- stdout ---'); print(r.stdout[:5000] or '(empty)')\n",
    "    print('--- stderr ---'); print(r.stderr[:5000] or '(empty)')\n",
    "    if r.returncode != 0:\n",
    "        _out_files = list(DOCKED_DIR.glob('*_out.pdbqt'))\n",
    "        if _out_files:\n",
    "            print(f'WARNING: unidock exit {r.returncode} but {len(_out_files)} output files found — continuing.')\n",
    "        else:\n",
    "            _write_error('docking', r.stdout[-3000:] + '\\n---stderr---\\n' + r.stderr)\n",
    "            raise RuntimeError('unidock failed (exit %d). stdout: %s\\nstderr: %s' % (r.returncode, r.stdout[-1000:], r.stderr[-2000:]))\n",
    "\n",
    "except Exception as e:\n",
    "    err = traceback.format_exc()\n",
    "    print(f'Docking error:\\n{err}')\n",
    "    _write_error('docking', err)\n",
    "    raise\n",
    "\n",
    "# List files created in working dir after docking\n",
    "import os\n",
    "all_files = []\n",
    "for root, dirs, files in os.walk('/kaggle/working'):\n",
    "    for fn in files:\n",
    "        fp = os.path.join(root, fn)\n",
    "        all_files.append(fp)\n",
    "print(f'Files in /kaggle/working after docking ({len(all_files)} total):')\n",
    "for fp in sorted(all_files)[:40]:\n",
    "    print(f'  {fp}  ({os.path.getsize(fp)} bytes)')\n",
    "\n",
    "print('Cell 7 done: docking complete')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-08",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import csv, pathlib, re\n",
    "\n",
    "working = pathlib.Path('/kaggle/working')\n",
    "\n",
    "# unidocktools unidock_pipeline writes <stem>_out.pdbqt into -o dir.\n",
    "docked = working / 'docked'\n",
    "out_pdbqts = sorted(docked.glob('*_out.pdbqt')) if docked.exists() else []\n",
    "if not out_pdbqts:  # fallback: search all of working\n",
    "    out_pdbqts = sorted(working.glob('**/*_out.pdbqt'))\n",
    "\n",
    "# Exclude padding ligands added to work around UniDock's 1-ligand batch bug\n",
    "out_pdbqts = [p for p in out_pdbqts if not p.stem.startswith('lig_pad_')]\n",
    "\n",
    "rows = []\n",
    "for pdbqt_path in out_pdbqts:\n",
    "    text = pdbqt_path.read_text(errors='replace')\n",
    "    # REMARK VINA RESULT:   -7.5  0.000  0.000\n",
    "    m = re.search(r'REMARK VINA RESULT:\\s+([-\\d.]+)\\s+([-\\d.]+)\\s+([-\\d.]+)', text)\n",
    "    if not m:\n",
    "        continue\n",
    "    rows.append({\n",
    "        'ligand':  pdbqt_path.stem.removesuffix('_out'),\n",
    "        'score':   float(m.group(1)),\n",
    "        'rmsd_lb': float(m.group(2)),\n",
    "        'rmsd_ub': float(m.group(3)),\n",
    "        '_path':   str(pdbqt_path),\n",
    "    })\n",
    "\n",
    "rows.sort(key=lambda r: r['score'])  # most-negative = best\n",
    "\n",
    "# Always write scores.csv so the local runner can detect an empty result\n",
    "with open('/kaggle/working/scores.csv', 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['ligand', 'score', 'rmsd_lb', 'rmsd_ub'])\n",
    "    w.writeheader()\n",
    "    if rows:\n",
    "        w.writerows({k: v for k, v in r.items() if k != '_path'} for r in rows)\n",
    "\n",
    "if not rows:\n",
    "    import json\n",
    "    pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "        json.dumps({'cell': 'results', 'message': 'Docking produced no scored poses. Check that docked/ contains *_out.pdbqt files.',\n",
    "                    'docked_files': [str(p) for p in working.glob('docked/**/*')]})\n",
    "    )\n",
    "\n",
    "# Convert top-25 poses to SDF so the local 3-D viewer works\n",
    "try:\n",
    "    from meeko import PDBQTMolecule, RDKitMolCreate\n",
    "    from rdkit.Chem import SDWriter\n",
    "    sdf_writer = SDWriter('/kaggle/working/poses.sdf')\n",
    "    n_written = 0\n",
    "    for row in rows[:25]:\n",
    "        try:\n",
    "            pm = PDBQTMolecule.from_file(row['_path'], skip_typing=True)\n",
    "            mols, _ = RDKitMolCreate.from_pdbqt_mol(pm)\n",
    "            for mol in mols:\n",
    "                if mol is not None:\n",
    "                    mol.SetProp('_Name', row['ligand'])\n",
    "                    mol.SetProp('score', str(row['score']))\n",
    "                    sdf_writer.write(mol)\n",
    "                    n_written += 1\n",
    "                    break  # first pose only\n",
    "        except Exception:\n",
    "            pass\n",
    "    sdf_writer.close()\n",
    "    print(f'  {n_written} poses written to poses.sdf')\n",
    "except Exception as e:\n",
    "    print(f'  SDF conversion skipped: {e}')\n",
    "\n",
    "print(f'Cell 8 done: {len(rows)} poses collected')\n"
   ]
  },

