    "# Receptor is already fully prepared locally (pdbfixer + meeko) and uploaded\n",
    "# as receptor.pdbqt -- use it directly, no need to re-run prep on Kaggle\n",
    "RECEPTOR_PDBQT = RECEPTOR_PATH\n",
    "assert RECEPTOR_PDBQT.exists(), f'Receptor PDBQT not found: {RECEPTOR_PDBQT}'\n",
    "print(f'Cell 5 done: receptor PDBQT ready -> {RECEPTOR_PDBQT}')\n"
