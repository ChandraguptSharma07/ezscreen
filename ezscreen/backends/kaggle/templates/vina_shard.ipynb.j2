   "source": [
    "import subprocess, sys\n",
    "\n",
    "def _run(cmd):\n",
    "    r = subprocess.run(cmd, shell=True, capture_output=True, text=True)\n",
    "    if r.returncode != 0:\n",
    "        import json, pathlib\n",
    "        pathlib.Path('/kaggle/working/error.json').write_text(\n",
    "            json.dumps({'cell': 'install', 'cmd': cmd, 'stderr': r.stderr[-2000:]})\n",
    "        )\n",
    "        raise RuntimeError(f'Install failed: {cmd}\\n{r.stderr[-500:]}')\n",
    "\n",
    "<% if engine == 'unidock-pro' %>\n",
    "# UniDock-Pro -- build from source\n",
    "_run('apt-get install -y cmake libboost-all-dev git 2>/dev/null')\n",
    "_run('rm -rf /tmp/unidock && git clone --depth 1 https://github.com/dptech-corp/Uni-Dock /tmp/unidock')\n",
    "_run('cmake -S /tmp/unidock/unidock -B /tmp/unidock/build -DCMAKE_BUILD_TYPE=Release -DCMAKE_CUDA_ARCHITECTURES=\"60;75\" && cmake --build /tmp/unidock/build -j$(nproc)')\n",
    "_run('ln -sf /tmp/unidock/build/unidock /usr/local/bin/unidock')\n",
    "<% else %>\n",
    "# UniDock -- build GPU binary from source to match Kaggle's installed CUDA toolkit.\n",
    "# Pre-built release binaries target CUDA 12.0; Kaggle P100 nodes run nvcc 12.8.\n",
    "# The ABI mismatch causes INT_MIN GPU group sizes and 0 docked poses at runtime.\n",
    "_run('pip install unidock-tools -q')\n",
    "\n",
    "import pathlib as _pl, os as _os, shutil as _sh\n",
    "_BIN = '/tmp/unidock/build/unidock'\n",
    "\n",
    "if _pl.Path(_BIN).exists() and _os.path.getsize(_BIN) > 500_000:\n",
    "    print(f'Reusing cached UniDock binary: {_BIN}')\n",
    "else:\n",
    "    print('Building UniDock from source (targeting Kaggle CUDA toolkit)...')\n",
    "    _run('apt-get install -y cmake libboost-all-dev git 2>/dev/null')\n",
    "    subprocess.run('nvcc --version 2>/dev/null || echo nvcc not found', shell=True)\n",
    "    _run('rm -rf /tmp/unidock && git clone --depth 1 https://github.com/dptech-corp/Uni-Dock /tmp/unidock')\n",
    "    _run('cmake -S /tmp/unidock/unidock -B /tmp/unidock/build -DCMAKE_BUILD_TYPE=Release -DCMAKE_CUDA_ARCHITECTURES=\"60;75\"')\n",
    "    _run('cmake --build /tmp/unidock/build -j$(nproc)')\n",
    "    print('UniDock source build complete')\n",
    "\n",
    "_run(f'ln -sf {_BIN} /usr/local/bin/unidock')\n",
    "assert _sh.which('unidock'), 'unidock not in PATH after symlink'\n",
    "_help_r = subprocess.run(['unidock', '--help'], capture_output=True, text=True)\n",
    "print(f'unidock binary: {_sh.which(\"unidock\")}')\n",
    "print('unidock --help exit:', _help_r.returncode)\n",
    "print((_help_r.stdout or _help_r.stderr)[:300])\n",
    "<% endif %>\n",
    "\n",
    "_run('pip install meeko -q')\n",
    "\n",
    "print('Cell 2 done: dependencies installed')\n"
   ]
  },

  {
   "cell_type": "code",
