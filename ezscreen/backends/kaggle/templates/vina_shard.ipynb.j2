    "    )\n",
    "\n",
    "# Convert top-25 poses to SDF so the local 3-D viewer works\n",
    "try:\n",
    "    from meeko import PDBQTMolecule, RDKitMolCreate\n",
    "    from rdkit.Chem import SDWriter\n",
    "    sdf_writer = SDWriter('/kaggle/working/poses.sdf')\n",
    "    n_written = 0\n",
    "    for row in rows[:25]:\n",
    "        try:\n",
    "            pm = PDBQTMolecule.from_file(row['_path'], skip_typing=True)\n",
    "            mols, _ = RDKitMolCreate.from_pdbqt_mol(pm)\n",
    "            for mol in mols:\n",
    "                if mol is not None:\n",
    "                    mol.SetProp('_Name', row['ligand'])\n",
    "                    mol.SetProp('score', str(row['score']))\n",
    "                    sdf_writer.write(mol)\n",
    "                    n_written += 1\n",
    "                    break  # first pose only\n",
    "        except Exception:\n",
    "            pass\n",
    "    sdf_writer.close()\n",
    "    print(f'  {n_written} poses written to poses.sdf')\n",
    "except Exception as e:\n",
    "    print(f'  SDF conversion skipped: {e}')\n",
    "\n",
    "print(f'Cell 8 done: {len(rows)} valid scores, {len(failed_rows)} rejected ({len(out_pdbqts)} pdbqts total)')\n"
