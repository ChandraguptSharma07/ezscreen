   "source": [
    "import csv, pathlib, glob\n",
    "\n",
    "working = pathlib.Path('/kaggle/working')\n",
    "score_files = list(working.glob('*.csv'))\n",
    "pose_files  = list(working.glob('*_out.sdf')) + list(working.glob('*.sdf'))\n",
    "\n",
    "# Consolidate scores\n",
    "rows = []\n",
    "for sf in score_files:\n",
    "    with sf.open() as f:\n",
    "        reader = csv.DictReader(f)\n",
    "        rows.extend(list(reader))\n",
    "\n",
    "rows.sort(key=lambda r: float(r.get('score', r.get('affinity', 0))))\n",
    "\n",
    "if rows:\n",
    "    fieldnames = list(rows[0].keys())\n",
    "    with open('/kaggle/working/scores.csv', 'w', newline='') as f:\n",
    "        writer = csv.DictWriter(f, fieldnames=fieldnames)\n",
    "        writer.writeheader()\n",
    "        writer.writerows(rows)\n",
    "\n",
    "print(f'Cell 8 done: {len(rows)} poses collected')\n"
   ]
