    "import json, os, pathlib, traceback\n",
    "\n",
    "ERROR_JSON = pathlib.Path('/kaggle/working/error.json')\n",
    "\n",
    "def _write_error(cell, msg):\n",
    "    ERROR_JSON.write_text(json.dumps({'cell': cell, 'message': msg}))\n",
    "\n",
    "BOX_CENTER  = [<< box_center[0] >>, << box_center[1] >>, << box_center[2] >>]\n",
    "BOX_SIZE    = [<< box_size[0] >>,   << box_size[1] >>,   << box_size[2] >>]\n",
    "SEARCH_MODE = '<< search_mode >>'\n",
    "GPU_IDS     = '<< gpu_ids >>'\n",
    "\n",
    "DOCKED_DIR = pathlib.Path('/kaggle/working/docked')\n",
    "DOCKED_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "import subprocess, shutil\n",
    "\n",
    "try:\n",
    "    _unidock_bin = shutil.which('unidock')\n",
    "    if _unidock_bin is None:\n",
    "        raise RuntimeError('unidock binary not found in PATH')\n",
    "    print(f'Using binary: {_unidock_bin}')\n",
    "    subprocess.run('nvidia-smi', shell=True)\n",
    "    print(f'Docking {len(pdbqt_files)} ligands in a single GPU batch')\n",
    "\n",
    "    cmd = [\n",
    "        _unidock_bin,\n",
    "        '--receptor', str(RECEPTOR_PDBQT),\n",
    "        '--gpu_batch', *pdbqt_files,\n",
    "        '--dir', str(DOCKED_DIR),\n",
    "        '--center_x', str(BOX_CENTER[0]),\n",
    "        '--center_y', str(BOX_CENTER[1]),\n",
    "        '--center_z', str(BOX_CENTER[2]),\n",
    "        '--size_x',   str(BOX_SIZE[0]),\n",
    "        '--size_y',   str(BOX_SIZE[1]),\n",
    "        '--size_z',   str(BOX_SIZE[2]),\n",
    "        '--search_mode', SEARCH_MODE,\n",
    "        '--scoring',     'vina',\n",
    "        *((['--gpu_ids', GPU_IDS]) if GPU_IDS else []),\n",
    "    ]\n",
    "    r = subprocess.run(cmd, capture_output=True, text=True)\n",
    "    _poses = list(DOCKED_DIR.glob('*_out.pdbqt'))\n",
    "    print(f'exit={r.returncode}  poses={len(_poses)}')\n",
    "    if r.stdout: print(r.stdout[-1000:])\n",
    "    if r.returncode != 0 and not _poses:\n",
    "        print(f'stderr: {r.stderr[-500:]}')\n",
    "\n",
    "except Exception as e:\n",
    "    err = traceback.format_exc()\n",
    "    print(f'Docking error:\\n{err}')\n",
    "    _write_error('docking', err)\n",
    "    raise\n",
    "\n",
    "print(f'Cell 7 done: docking complete ({len(list(DOCKED_DIR.glob(\"*_out.pdbqt\")))} poses)')\n"
   ]
  },

  {
   "cell_type": "code",
   "id": "cell-08",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import csv, math, pathlib, re\n",
    "\n",
    "working = pathlib.Path('/kaggle/working')\n",
    "\n",
    "# unidocktools unidock_pipeline writes <stem>_out.pdbqt into -o dir.\n",
    "docked = working / 'docked'\n",
    "out_pdbqts = sorted(docked.glob('*_out.pdbqt')) if docked.exists() else []\n",
    "if not out_pdbqts:  # fallback: search all of working\n",
    "    out_pdbqts = sorted(working.glob('**/*_out.pdbqt'))\n",
    "\n",
    "# Exclude padding ligands added to work around UniDock's 1-ligand batch bug\n",
    "out_pdbqts = [p for p in out_pdbqts if not p.stem.startswith('lig_pad_')]\n",
    "\n",
    "# Permissive pattern: capture any non-whitespace token after RESULT: so we\n",
    "# catch nan/inf/scientific-notation overflow values instead of silently dropping them.\n",
    "_RESULT_RE = re.compile(r'REMARK VINA RESULT:\\s+(\\S+)\\s+(\\S+)\\s+(\\S+)')\n",
    "_SCORE_FLOOR = -20.0   # below this = GPU underflow artifact\n",
    "_SCORE_CEIL  =  0.0   # at or above = GPU overflow / no valid pose\n",
    "\n",
    "rows = []          # valid scores that will go into scores.csv\n",
    "failed_rows = []   # everything else, with a reason\n",
    "\n",
    "for pdbqt_path in out_pdbqts:\n",
    "    lig_id = pdbqt_path.stem.removesuffix('_out')\n",
    "    text = pdbqt_path.read_text(errors='replace')\n",
    "    m = _RESULT_RE.search(text)\n",
    "    if not m:\n",
    "        failed_rows.append({'ligand': lig_id, 'raw_score': '', 'reason': 'no_remark'})\n",
    "        continue\n",
    "    raw = m.group(1)\n",
    "    try:\n",
    "        score = float(raw)\n",
    "    except ValueError:\n",
    "        failed_rows.append({'ligand': lig_id, 'raw_score': raw, 'reason': 'unparseable_score'})\n",
    "        continue\n",
    "    if not math.isfinite(score):\n",
    "        failed_rows.append({'ligand': lig_id, 'raw_score': raw, 'reason': 'non_finite_score'})\n",
    "        continue\n",
    "    if score >= _SCORE_CEIL:\n",
    "        failed_rows.append({'ligand': lig_id, 'raw_score': raw, 'reason': 'score_ceiling'})\n",
    "        continue\n",
    "    if score < _SCORE_FLOOR:\n",
    "        failed_rows.append({'ligand': lig_id, 'raw_score': raw, 'reason': 'score_floor'})\n",
    "        continue\n",
    "    try:\n",
    "        rmsd_lb = float(m.group(2))\n",
    "        rmsd_ub = float(m.group(3))\n",
    "    except ValueError:\n",
    "        rmsd_lb = rmsd_ub = 0.0\n",
    "    rows.append({\n",
    "        'ligand':  lig_id,\n",
    "        'score':   score,\n",
    "        'rmsd_lb': rmsd_lb,\n",
    "        'rmsd_ub': rmsd_ub,\n",
    "        '_path':   str(pdbqt_path),\n",
    "    })\n",
    "\n",
    "rows.sort(key=lambda r: r['score'])  # most-negative = best\n",
    "\n",
    "# Always write scores.csv so the local runner can detect an empty result\n",
    "with open('/kaggle/working/scores.csv', 'w', newline='') as f:\n",
    "    w = csv.DictWriter(f, fieldnames=['ligand', 'score', 'rmsd_lb', 'rmsd_ub'])\n",
